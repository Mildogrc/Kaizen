// Hyperlearning — database schema
// Single-user, local-first. Content is schema-driven: ContentSchema defines the
// shape of LearningItem.data JSON, validated with Zod at import time.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CourseCategory {
  LANGUAGE
  MATH
  CERTIFICATION
  BOOK
  SKILL
  CUSTOM
}

/// Which main tab a course is surfaced under.
enum CourseTab {
  JAPANESE
  CHINESE
  MATH
  SKILLS
  BOOKS
  CUSTOM
}

enum CourseStatus {
  ACTIVE
  PLANNED
  PAUSED
  COMPLETED
  ARCHIVED
}

enum GoalStatus {
  ACTIVE
  PLANNED
  COMPLETED
  ABANDONED
}

enum FieldType {
  TEXT
  LONG_TEXT
  NUMBER
  BOOLEAN
  ENUM
  LIST
  OBJECT
  AUDIO
  IMAGE
  MARKDOWN
  CODE
  LATEX
  JSON
  DATE
  URL
}

enum PracticeType {
  FLASHCARD
  CLOZE
  RECOGNITION
  PRODUCTION
  MULTIPLE_CHOICE
  FREE_RECALL
  FILL_BLANK
  TYPING_DRILL
  MATCHING
  ORDERING
  PROOF_RECONSTRUCTION
  PROBLEM_SOLVING
  MISTAKE_REVIEW
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum CardMaturity {
  NEW
  LEARNING
  YOUNG
  MATURE
}

enum NodeStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum NodeLevel {
  FOUNDATION
  CORE
  ADVANCED
  TARGET
}

enum EdgeKind {
  PREREQUISITE
  /// dotted "this is useful for / applied in" edge
  APPLICATION
}

enum BookStatus {
  WANT_TO_READ
  READING
  FINISHED
  PAUSED
  ABANDONED
}

enum BookNoteKind {
  NOTE
  QUOTE
  SUMMARY
  IDEA
  CHARACTER
  ARGUMENT
  DEFINITION
  FORMULA
  PASSAGE
  REFLECTION
}

enum ImportStatus {
  PENDING
  VALIDATED
  PARTIAL
  COMPLETED
  FAILED
}

enum GrammarStudyStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

enum GrammarLessonStatus {
  GENERATED
  COMPLETED
}

enum ReadingMode {
  RSVP
  PACED
  CHUNKING
  BENCHMARK
}

enum MandarinEntryKind {
  CHARACTER
  WORD
}

// ---------------------------------------------------------------------------
// User & courses
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
}

model Course {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String?
  category    CourseCategory
  tab         CourseTab
  status      CourseStatus   @default(ACTIVE)
  color       String? // accent color used in the UI
  metadata    Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  goals         CourseGoal[]
  plans         CoursePlan[]
  milestones    CourseMilestone[]
  schemas       ContentSchema[]
  learningItems LearningItem[]
  practiceItems PracticeItem[]
  flashcards    Flashcard[]
  exams         Exam[]
  roadmaps      Roadmap[]
  mistakes      Mistake[]
  importBatches ImportBatch[]
  books         Book[]
  ankiMappings  AnkiDeckMapping[]
}

model CourseGoal {
  id           String     @id @default(cuid())
  courseId     String
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  /// e.g. "vocab_count", "exam_prep", "roadmap_target", "custom"
  goalType     String     @default("custom")
  targetValue  Int?
  currentValue Int        @default(0)
  unit         String? // "words", "kanji", "nodes", ...
  targetDate   DateTime?
  examLevelId  String?
  examLevel    ExamLevel? @relation(fields: [examLevelId], references: [id], onDelete: SetNull)
  status       GoalStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  plans CoursePlan[]

  @@index([courseId, status])
}

model CoursePlan {
  id          String      @id @default(cuid())
  courseId    String
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  goalId      String?
  goal        CourseGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  name        String
  description String?
  status      GoalStatus  @default(ACTIVE)
  /// structured plan payload (phases, weekly load, queues)
  plan        Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  milestones CourseMilestone[]
}

model CourseMilestone {
  id          String      @id @default(cuid())
  courseId    String
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  planId      String?
  plan        CoursePlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  title       String
  description String?
  order       Int         @default(0)
  metric      String? // e.g. "words", "kanji"
  targetValue Int?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([courseId, order])
}

// ---------------------------------------------------------------------------
// Schema system (the extensibility core)
// ---------------------------------------------------------------------------

model ContentSchema {
  id          String         @id @default(cuid())
  courseId    String?
  course      Course?        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String         @unique
  name        String
  /// item type this schema describes, e.g. "JapaneseVocabularyItem"
  itemType    String
  category    CourseCategory @default(CUSTOM)
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  versions      ContentSchemaVersion[]
  learningItems LearningItem[]
  ankiMappings  AnkiDeckMapping[]
}

model ContentSchemaVersion {
  id        String        @id @default(cuid())
  schemaId  String
  schema    ContentSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)
  version   Int           @default(1)
  /// Non-field rules: flashcardRules, practiceRules, srsRules,
  /// importInstructions, exportInstructions, llmPrompt, completionCriteria
  config    Json          @default("{}")
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())

  fields        ContentSchemaField[]
  learningItems LearningItem[]
  importBatches ImportBatch[]

  @@unique([schemaId, version])
}

model ContentSchemaField {
  id                 String               @id @default(cuid())
  versionId          String
  schemaVersion      ContentSchemaVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  name               String // machine name, e.g. "reading"
  label              String // display label
  description        String?
  fieldType          FieldType
  required           Boolean              @default(false)
  order              Int                  @default(0)
  /// { minLength, maxLength, min, max, pattern, itemType, ... }
  validationRules    Json                 @default("{}")
  enumOptions        Json? // string[] when fieldType = ENUM
  exampleValue       Json?
  defaultValue       Json?
  importInstructions String?
  llmInstructions    String?

  @@unique([versionId, name])
  @@index([versionId, order])
}

// ---------------------------------------------------------------------------
// Content, practice, review
// ---------------------------------------------------------------------------

model LearningItem {
  id              String                @id @default(cuid())
  courseId        String
  course          Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  schemaId        String?
  contentSchema   ContentSchema?        @relation(fields: [schemaId], references: [id], onDelete: SetNull)
  schemaVersionId String?
  schemaVersion   ContentSchemaVersion? @relation(fields: [schemaVersionId], references: [id], onDelete: SetNull)
  itemType        String // denormalized, e.g. "JapaneseVocabularyItem"
  /// schema-validated structured content
  data            Json
  roadmapNodeId   String?
  roadmapNode     RoadmapNode?          @relation(fields: [roadmapNodeId], references: [id], onDelete: SetNull)
  sourceId        String?
  source          Source?               @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  importBatchId   String?
  importBatch     ImportBatch?          @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  practiceItems   PracticeItem[]
  flashcards      Flashcard[]
  tags            Tag[]
  grammarProgress GrammarProgress?

  sourceKey String?

  @@unique([courseId, itemType, sourceKey])
  @@index([courseId, itemType])
}

model PracticeItem {
  id             String        @id @default(cuid())
  courseId       String
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningItemId String?
  learningItem   LearningItem? @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  roadmapNodeId  String?
  roadmapNode    RoadmapNode?  @relation(fields: [roadmapNodeId], references: [id], onDelete: SetNull)
  type           PracticeType
  prompt         String
  answer         String
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())

  review   ReviewRecord?
  attempts Attempt[]
  mistakes Mistake[]

  @@index([courseId, type])
}

model Flashcard {
  id             String        @id @default(cuid())
  courseId       String
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningItemId String?
  learningItem   LearningItem? @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  bookNoteId     String?
  bookNote       BookNote?     @relation(fields: [bookNoteId], references: [id], onDelete: SetNull)
  front          String
  back           String
  notes          String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())

  review   ReviewRecord?
  attempts Attempt[]
  tags     Tag[]

  @@index([courseId])
}

/// SM-2-style spaced repetition state for a flashcard OR practice item.
model ReviewRecord {
  id             String        @id @default(cuid())
  flashcardId    String?       @unique
  flashcard      Flashcard?    @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  practiceItemId String?       @unique
  practiceItem   PracticeItem? @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)
  ease           Float         @default(2.5)
  intervalDays   Float         @default(0)
  dueAt          DateTime      @default(now())
  repetitions    Int           @default(0)
  lapseCount     Int           @default(0)
  lastRating     ReviewRating?
  lastReviewedAt DateTime?
  maturity       CardMaturity  @default(NEW)
  isLeech        Boolean       @default(false)
  isSuspended    Boolean       @default(false)

  @@index([dueAt, isSuspended])
}

model Attempt {
  id             String        @id @default(cuid())
  flashcardId    String?
  flashcard      Flashcard?    @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  practiceItemId String?
  practiceItem   PracticeItem? @relation(fields: [practiceItemId], references: [id], onDelete: Cascade)
  sessionId      String?
  session        StudySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  rating         ReviewRating?
  correct        Boolean?
  answerGiven    String?
  timeMs         Int?
  createdAt      DateTime      @default(now())

  @@index([createdAt])
}

model Mistake {
  id             String        @id @default(cuid())
  courseId       String
  course         Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  practiceItemId String?
  practiceItem   PracticeItem? @relation(fields: [practiceItemId], references: [id], onDelete: SetNull)
  description    String
  category       String? // "vocab", "grammar", "sign-error", ...
  count          Int           @default(1)
  resolved       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([courseId, resolved])
}

model StudySession {
  id          String    @id @default(cuid())
  date        DateTime  @default(now())
  mode        String    @default("balanced")
  durationMin Int?
  stats       Json      @default("{}")
  attempts    Attempt[]

  @@index([date])
}

model Tag {
  id            String         @id @default(cuid())
  name          String         @unique
  learningItems LearningItem[]
  flashcards    Flashcard[]
  books         Book[]
}

model Source {
  id            String         @id @default(cuid())
  name          String
  type          String // "book", "website", "media", "course", ...
  url           String?
  metadata      Json           @default("{}")
  learningItems LearningItem[]
}

model ImportBatch {
  id              String                @id @default(cuid())
  courseId        String
  course          Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  schemaVersionId String?
  schemaVersion   ContentSchemaVersion? @relation(fields: [schemaVersionId], references: [id], onDelete: SetNull)
  sourceName      String? // filename or "pasted JSON" / "LLM generation"
  format          String                @default("json") // "json" | "csv"
  status          ImportStatus          @default(PENDING)
  totalCount      Int                   @default(0)
  validCount      Int                   @default(0)
  errorCount      Int                   @default(0)
  errors          Json                  @default("[]")
  createdAt       DateTime              @default(now())

  learningItems LearningItem[]
}

// ---------------------------------------------------------------------------
// Roadmaps (Math primarily; also usable for language test paths)
// ---------------------------------------------------------------------------

model Roadmap {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  nodes RoadmapNode[]
  edges RoadmapEdge[]
}

model RoadmapNode {
  id          String     @id @default(cuid())
  roadmapId   String
  roadmap     Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  /// grouping, e.g. "Algebra", "Analysis", "Topology & Geometry"
  branch      String?
  level       NodeLevel  @default(CORE)
  isTarget    Boolean    @default(false)
  status      NodeStatus @default(NOT_STARTED)
  order       Int        @default(0)
  /// textbooks, theorem/definition counts, notes
  metadata    Json       @default("{}")

  outgoingEdges RoadmapEdge[]  @relation("EdgeFrom")
  incomingEdges RoadmapEdge[]  @relation("EdgeTo")
  learningItems LearningItem[]
  practiceItems PracticeItem[]

  @@unique([roadmapId, slug])
  @@index([roadmapId, branch])
}

model RoadmapEdge {
  id         String      @id @default(cuid())
  roadmapId  String
  roadmap    Roadmap     @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  fromNodeId String
  fromNode   RoadmapNode @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNodeId   String
  toNode     RoadmapNode @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  kind       EdgeKind    @default(PREREQUISITE)

  @@unique([fromNodeId, toNodeId, kind])
}

// ---------------------------------------------------------------------------
// Books
// ---------------------------------------------------------------------------

model Book {
  id              String     @id @default(cuid())
  title           String
  author          String?
  category        String?
  status          BookStatus @default(WANT_TO_READ)
  startDate       DateTime?
  finishDate      DateTime?
  rating          Int? // 1..5
  pageCount       Int?
  sourceLanguage  String?
  relatedCourseId String?
  relatedCourse   Course?    @relation(fields: [relatedCourseId], references: [id], onDelete: SetNull)
  metadata        Json       @default("{}")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  notes           BookNote[]
  readingSessions BookReadingSession[]
  tags            Tag[]

  @@index([status])
}

/// One model covers notes, quotes, summaries, ideas, characters, arguments,
/// definitions, formulas, passages, reflections — discriminated by `kind`.
model BookNote {
  id        String       @id @default(cuid())
  bookId    String
  book      Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  kind      BookNoteKind @default(NOTE)
  content   String
  /// chapter / page / location reference
  location  String?
  /// marked "remember this" → eligible for flashcard generation
  remember  Boolean      @default(false)
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  flashcards Flashcard[]

  @@index([bookId, kind])
  @@index([remember])
}

model BookReadingSession {
  id          String   @id @default(cuid())
  bookId      String
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  readAt      DateTime @default(now())
  startPage   Int?
  endPage     Int?
  pagesRead   Int
  durationMin Int
  notes       String?
  createdAt   DateTime @default(now())

  @@index([bookId, readAt])
}

// ---------------------------------------------------------------------------
// Japanese grammar coach
// ---------------------------------------------------------------------------

model GrammarProgress {
  id              String             @id @default(cuid())
  learningItemId  String             @unique
  learningItem    LearningItem       @relation(fields: [learningItemId], references: [id], onDelete: Cascade)
  status          GrammarStudyStatus @default(NEW)
  curriculumOrder Int                @default(0)
  ease            Float              @default(2.5)
  intervalDays    Float              @default(0)
  dueAt           DateTime           @default(now())
  repetitions     Int                @default(0)
  lapseCount      Int                @default(0)
  isLeech         Boolean            @default(false)
  introducedAt    DateTime?
  lastStudiedAt   DateTime?
  lastRating      ReviewRating?
  totalCorrect    Int                @default(0)
  totalQuestions  Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, dueAt])
  @@index([curriculumOrder])
}

model GrammarLesson {
  id             String              @id @default(cuid())
  scheduledFor   DateTime            @default(now())
  levelLabel     String
  prompt         String
  grammarItemIds Json
  vocabulary     Json                @default("[]")
  status         GrammarLessonStatus @default(GENERATED)
  response       Json?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())

  @@index([scheduledFor, status])
}

// ---------------------------------------------------------------------------
// Codeforces tracking
// ---------------------------------------------------------------------------

model CodeforcesProfile {
  id           String    @id @default(cuid())
  handle       String    @unique
  profileUrl   String
  displayName  String?
  rating       Int?
  maxRating    Int?
  rank         String?
  maxRank      String?
  avatarUrl    String?
  contribution Int?
  lastSyncedAt DateTime?
  syncError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  submissions   CodeforcesSubmission[]
  ratingChanges CodeforcesRatingChange[]
}

model CodeforcesSubmission {
  id                  String            @id @default(cuid())
  profileId           String
  profile             CodeforcesProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  codeforcesId        BigInt
  contestId           Int?
  problemIndex        String
  problemName         String
  problemRating       Int?
  problemTags         Json              @default("[]")
  verdict             String?
  participantType     String?
  programmingLanguage String?
  submittedAt         DateTime
  timeConsumedMillis  Int?
  memoryConsumedBytes BigInt?

  @@unique([profileId, codeforcesId])
  @@index([profileId, submittedAt])
  @@index([profileId, problemRating])
}

model CodeforcesRatingChange {
  id          String            @id @default(cuid())
  profileId   String
  profile     CodeforcesProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  contestId   Int
  contestName String
  contestRank Int
  oldRating   Int
  newRating   Int
  updatedAt   DateTime

  @@unique([profileId, contestId])
  @@index([profileId, updatedAt])
}

// ---------------------------------------------------------------------------
// Speed reading
// ---------------------------------------------------------------------------

model SpeedReadingPassage {
  id         String   @id @default(cuid())
  title      String
  topic      String
  category   String
  difficulty String
  sourceUrl  String?
  text       String
  wordCount  Int
  questions  Json
  answerKey  Json
  source     String   @default("llm")
  createdAt  DateTime @default(now())

  sessions SpeedReadingSession[]

  @@index([category, difficulty])
}

model SpeedReadingSession {
  id                   String              @id @default(cuid())
  passageId            String
  passage              SpeedReadingPassage @relation(fields: [passageId], references: [id], onDelete: Cascade)
  mode                 ReadingMode
  wpm                  Int
  chunkSize            Int
  fontSize             Int
  punctuationPause     Boolean             @default(true)
  startedAt            DateTime
  completedAt          DateTime            @default(now())
  durationSec          Int
  correctAnswers       Int
  totalQuestions       Int
  accuracy             Float
  responseTimeMs       Int
  estimatedRetention   Float
  recommendedNextWpm   Int
  answers              Json
  retentionDueAt       DateTime?
  retentionCompletedAt DateTime?
  retentionAccuracy    Float?
  retentionAnswers     Json?

  @@index([completedAt])
  @@index([retentionDueAt, retentionCompletedAt])
}

// ---------------------------------------------------------------------------
// Mandarin Blueprint — level catalog, cached dictionary entries, Anki exports
// ---------------------------------------------------------------------------

model MandarinBlueprintLevel {
  id                        String   @id @default(cuid())
  level                     Int      @unique
  phase                     Int?
  reportedNewCharacterCount Int
  reportedTotalCharacters   Int
  reportedNewWordCount      Int
  reportedTotalWords        Int
  characters                Json     @default("[]")
  words                     Json     @default("[]")
  sourceStats               Json     @default("{}")
  completedAt               DateTime?
  pushedAt                  DateTime?
  pushError                 String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([completedAt])
}

model MandarinDictionaryEntry {
  id          String            @id @default(cuid())
  surface     String
  kind        MandarinEntryKind
  traditional String?
  pinyin      Json              @default("[]")
  definitions Json              @default("[]")
  audioUrls   Json              @default("[]")
  sourceUrl   String
  fetchedAt   DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([surface, kind])
  @@index([kind, surface])
}

// ---------------------------------------------------------------------------
// Anki integration — Anki is the review engine for mapped decks; the app
// snapshots deck/card/review data via AnkiConnect and runs analytics on it.
// ---------------------------------------------------------------------------

enum AnkiCardState {
  NEW
  LEARNING
  YOUNG
  MATURE
  SUSPENDED
  BURIED
}

model AnkiDeckMapping {
  id               String         @id @default(cuid())
  deckName         String         @unique
  courseId         String
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  /// optional subsection anchor, e.g. japanese-grammar
  schemaId         String?
  contentSchema    ContentSchema? @relation(fields: [schemaId], references: [id], onDelete: SetNull)
  /// mature cards from this deck feed the known-word count
  countsKnownWords Boolean        @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime       @default(now())

  cards      AnkiCardSnapshot[]
  reviewLogs AnkiReviewLog[]

  @@index([courseId])
}

model AnkiCardSnapshot {
  id           String          @id @default(cuid())
  mappingId    String
  mapping      AnkiDeckMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  ankiCardId   BigInt          @unique
  front        String
  back         String
  state        AnkiCardState
  intervalDays Int             @default(0)
  ease         Float           @default(2.5)
  dueAt        DateTime?
  reps         Int             @default(0)
  lapses       Int             @default(0)
  isLeech      Boolean         @default(false)
  syncedAt     DateTime        @updatedAt

  @@index([mappingId, state])
  @@index([mappingId, dueAt])
}

model AnkiReviewLog {
  id                 String          @id @default(cuid())
  /// Anki revlog id: epoch milliseconds of the review, unique per card
  ankiReviewId       BigInt
  mappingId          String
  mapping            AnkiDeckMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  ankiCardId         BigInt
  reviewedAt         DateTime
  /// 1=again 2=hard 3=good 4=easy
  rating             Int
  intervalAfterDays  Int             @default(0)
  intervalBeforeDays Int             @default(0)
  timeMs             Int             @default(0)

  @@unique([ankiReviewId, ankiCardId])
  @@index([mappingId, reviewedAt])
}

model AnkiSyncRun {
  id           String    @id @default(cuid())
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    @default("running") // running | ok | error
  decksSynced  Int       @default(0)
  cardsSynced  Int       @default(0)
  reviewsAdded Int       @default(0)
  error        String?

  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Known words — union of Migaku exports, Anki mature cards, and manual adds.
// Japanese entries carry two canonical keys so union cardinality can be
// reported as a lower/upper bound; Chinese keys are exact (simplified form).
// ---------------------------------------------------------------------------

model KnownWord {
  id           String   @id @default(cuid())
  language     String // 'ja' | 'zh'
  surface      String // as imported
  lemma        String // dictionary form (ja) / simplified form (zh)
  reading      String? // katakana reading of the lemma (ja)
  /// merge only when certain: ja = lemma|reading, zh = simplified form
  strictKey    String
  /// merge aggressively: ja = lemma, zh = simplified form
  looseKey     String
  source       String // 'migaku' | 'anki' | 'manual'
  sourceDetail String? // deck name or import label
  createdAt    DateTime @default(now())

  @@unique([language, source, strictKey])
  @@index([language, looseKey])
}

model KnownWordStat {
  id          String   @id @default(cuid())
  date        DateTime // start of day
  language    String
  lower       Int
  upper       Int
  migakuCount Int      @default(0)
  ankiCount   Int      @default(0)
  manualCount Int      @default(0)

  @@unique([date, language])
  @@index([language, date])
}

// ---------------------------------------------------------------------------
// Exams
// ---------------------------------------------------------------------------

model Exam {
  id          String  @id @default(cuid())
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String  @unique
  name        String
  description String?

  levels ExamLevel[]
}

model ExamLevel {
  id          String  @id @default(cuid())
  examId      String
  exam        Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  name        String // "N5", "HSK 4", "Pre-2"
  /// ascending difficulty within the exam
  rank        Int
  description String?
  /// { targetVocab, targetKanji, targetChars, ... } editable placeholders
  targets     Json    @default("{}")

  objectives ExamObjective[]
  goals      CourseGoal[]

  @@unique([examId, rank])
}

model ExamObjective {
  id          String    @id @default(cuid())
  examLevelId String
  examLevel   ExamLevel @relation(fields: [examLevelId], references: [id], onDelete: Cascade)
  title       String
  /// "vocabulary" | "grammar" | "kanji" | "reading" | "listening" | ...
  category    String
  targetCount Int?
  description String?
  completed   Boolean   @default(false)

  @@index([examLevelId])
}
